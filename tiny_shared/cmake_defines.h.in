#pragma once

#include <cstddef>
#include <string>

namespace tiny {

struct Cmake_defines {
    static inline const auto base_identifier = std::string{"@tiny_base_identifier@"};
    static inline const auto product_name = std::string{"@tiny_product_name@"};
    static inline const auto product_short_name = std::string{"@tiny_product_short_name@"};
    static inline const auto version_string = std::string{"@tiny_version_string@"};
    static inline const auto build_number = size_t{@tiny_build_number@};
    static inline const auto auv2_manufacturer = uint32_t{'@tiny_auv2_manufacturer@'};
    static inline const auto auv2_type = uint32_t{'@tiny_auv2_type@'};
    static inline const auto auv2_subtype = uint32_t{'@tiny_auv2_subtype@'};
};

} // namespace tiny