#pragma once

#include <array>
#include <cstddef>

#define TINY_AUV2_VIEW_CLASS @TINY_AUV2_VIEW_CLASS@
static const unsigned int kAudioUnitProperty_UserPlugin = 64000; // User properties have to be >= 64000.

#define TINY_WANTS_SIDECHAIN @TINY_WANTS_SIDECHAIN@

namespace tiny {

struct Plug_info {
    static constexpr const char company_name[] = "@TINY_COMPANY_NAME@";
    static constexpr const char company_website[] = "@TINY_COMPANY_WEBSITE@";
    static constexpr const char company_email[] = "@TINY_COMPANY_EMAIL@";
    static constexpr const char company_directory_name[] = "@TINY_COMPANY_DIRECTORY_NAME@";

    static constexpr auto framework_code = uint32_t{'@TINY_FRAMEWORK_CODE@'};
    static constexpr auto manufacturer_code = uint32_t{'@TINY_MANUFACTURER_CODE@'};
    static constexpr auto plugin_code = uint32_t{'@TINY_PLUGIN_CODE@'};

    static constexpr const char product_name[] = "@TINY_PRODUCT_NAME@";
    static constexpr const char product_directory_name[] = "@TINY_PRODUCT_DIRECTORY_NAME@";

    static constexpr const char plugin_name[] = "@TINY_PLUGIN_NAME@";
    static constexpr const char plugin_short_name[] = "@TINY_PLUGIN_SHORT_NAME@";

    static constexpr const char base_file_name[] = "@TINY_BASE_FILENAME@";
    static constexpr const char base_identifier[] = "@TINY_BASE_IDENTIFIER@";
    static constexpr const char version_string[] = "@TINY_VERSION_STRING@";
    static constexpr auto build_number = size_t{@TINY_BUILD_NUMBER@};

    static constexpr auto wants_sidechain = bool{@TINY_PLUGIN_WANTS_SIDECHAIN@};
    static constexpr auto can_process_mono = bool{@TINY_PLUGIN_CAN_PROCESS_MONO@};

    static constexpr const char app_group_id[] = "@TINY_APP_GROUP_ID@";

    struct Aax {
        static constexpr auto manufacturer_id = uint32_t{'@TINY_MANUFACTURER_CODE@'};
        static constexpr auto product_id = uint32_t{'@TINY_PLUGIN_CODE@'};
        static constexpr auto plugin_id = uint32_t{}; // One plug-in per product.
    };

    struct Auv2 {
        static constexpr const char bundle_id[] = "@TINY_BASE_IDENTIFIER@.component";
        static constexpr const char view_class[] = "@TINY_AUV2_VIEW_CLASS@";
        static constexpr auto manufacturer = uint32_t{'@TINY_MANUFACTURER_CODE@'};
        static constexpr auto type = uint32_t{'@TINY_AUV2_TYPE@'};
        static constexpr auto subtype = uint32_t{'@TINY_PLUGIN_CODE@'};
    };

    struct Clap {
        using Feature_list = std::array<const char*, @TINY_CLAP_FEATURE_COUNT@>;
        static constexpr char description[] = "@TINY_CLAP_DESCRIPTION@";
        static constexpr auto features = Feature_list{@TINY_CLAP_FEATURE_VALUES@};
        static constexpr char factory_preset_discovery_id[] = "@TINY_BASE_IDENTIFIER@.factory-preset-discovery";
        static constexpr char user_preset_discovery_id[] = "@TINY_BASE_IDENTIFIER@.user-preset-discovery";
    };

    struct Vst3 {
        using Uid_arr = std::array<uint32_t, 4>;
        static constexpr auto controller_uid = Uid_arr{@TINY_VST3_CONTROLLER_UID_LITERALS@};
        static constexpr auto processor_uid = Uid_arr{@TINY_VST3_PROCESSOR_UID_LITERALS@};
        static constexpr char subcategories[] = "@TINY_VST3_SUBCATEGORIES@";
    };

    struct Presets {
        static constexpr auto version = size_t{@TINY_PRESET_VERSION@};
        static constexpr char extension[] = "@TINY_PRESET_EXTENSION@";
    };
};

} // namespace tiny