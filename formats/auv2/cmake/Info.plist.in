<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple Computer//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>AudioComponents</key>
	<array>
		<dict>
			<key>name</key>
			<string>${TINY_COMPANY_NAME}: ${TINY_PRODUCT_NAME}</string>
			<key>description</key>
			<string>${TINY_PRODUCT_NAME}</string>
			<key>factoryFunction</key>
			<string>Auv2_effectFactory</string>
			<key>manufacturer</key>
			<string>${TINY_MANUFACTURER_CODE}</string>
			<key>sandboxSafe</key>
			<true/>
			<key>subtype</key>
			<string>${TINY_PLUGIN_CODE}</string>
			<key>tags</key>
			<array>
				${TINY_AUDIO_COMPONENT_TAGS}
			</array>
			<key>type</key>
			<string>${TINY_AUV2_TYPE}</string>
			<key>version</key>
			<integer>${TINY_BUNDLE_VERSION_INT}</integer>
		</dict>
	</array>
	<key>CFBundleDevelopmentRegion</key>
	<string>English</string>
	<key>CFBundleExecutable</key>
	<string>${TINY_BASE_FILENAME}</string>
	<key>CFBundleGetInfoString</key>
	<string>${MACOSX_BUNDLE_INFO_STRING}</string>
	<key>CFBundleIconFile</key>
	<string>${MACOSX_BUNDLE_ICON_FILE}</string>
	<key>CFBundleIdentifier</key>
	<string>${TINY_AUV2_BUNDLE_IDENTIFIER}</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleLongVersionString</key>
	<string>${MACOSX_BUNDLE_LONG_VERSION_STRING}</string>
	<key>CFBundleName</key>
	<string>${TINY_PRODUCT_NAME}</string>
	<key>CFBundlePackageType</key>
	<string>BNDL</string>
	<key>CFBundleShortVersionString</key>
	<string>${TINY_VERSION_STRING}</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>${TINY_BUILD_NUMBER}</string>
	<key>CSResourcesFileMapped</key>
	<true/>
	<key>NSHumanReadableCopyright</key>
	<string>${TINY_COMPANY_NAME}</string>
</dict>
</plist>
