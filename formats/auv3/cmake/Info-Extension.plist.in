<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>${TINY_AUV3_IDENTIFIER}</string>
    <key>CFBundleName</key>
    <string>${TINY_PRODUCT_NAME}</string>
    <key>CFBundleDisplayName</key>
    <string>${TINY_PRODUCT_NAME}</string>
    <key>CFBundleVersion</key>
    <string>${TINY_BUILD_NUMBER}</string>
    <key>CFBundleShortVersionString</key>
    <string>${TINY_VERSION_STRING}</string>
    <key>CFBundleExecutable</key>
    <string>${TINY_BASE_FILENAME}_AUv3</string>
	<key>NSExtension</key>
	<dict>
		<key>NSExtensionAttributes</key>
		<dict>
			<key>AudioComponents</key>
            <array>
                <dict>
                    <key>description</key>
                    <string>${TINY_PRODUCT_NAME}</string>
                    <key>factoryFunction</key>
                    <string>Auv3_AUViewController</string>
                    <key>manufacturer</key>
                    <string>${TINY_MANUFACTURER_CODE}</string>
                    <key>name</key>
                    <string>${TINY_COMPANY_NAME}: ${TINY_PLUGIN_NAME}</string>
                    <key>sandboxSafe</key>
                    <true/>
                    <key>subtype</key>
                    <string>${TINY_PLUGIN_CODE}</string>
                    <key>tags</key>
                    <array>
                        <string>Effect</string>
                        ${TINY_AUV3_TAGS}
                    </array>
                    <key>type</key>
                    <string>${TINY_AUV2_TYPE}</string>
                    <key>version</key>
                    <integer>${TINY_AUV3_BUILD_NUMBER}</integer>
                </dict>
            </array>
		</dict>
		<key>NSExtensionPrincipalClass</key>
		<string>Auv3_AUViewController</string>
		<key>NSExtensionPointIdentifier</key>
		<string>com.apple.AudioUnit-UI</string>
	</dict>
</dict>
</plist>
